# ============================================================
# CineScope — Environment Variables
# ============================================================
# Copy this file to .env and fill in your real keys.
#
#   cp .env.example .env
#
# NEVER commit .env — it's already in .gitignore.
# ============================================================

# ──── SERVER-SIDE KEYS (Vercel Environment Variables) ────
# These go in Vercel's dashboard (Settings → Environment Variables).
# They are NEVER exposed to the browser.
#
# TMDB_API_KEY=
# TRAKT_CLIENT_ID=
# GEMINI_API_KEY=

# ──── CLIENT-SIDE (safe to be in browser) ────
# Google OAuth Client ID is PUBLIC by design — Google enforces
# security through authorized redirect URIs, not client ID secrecy.
VITE_GOOGLE_CLIENT_ID=

# ──── LOCAL DEVELOPMENT SHORTCUT ────
# Set this to "true" to skip the serverless proxy and call APIs directly.
# Only use this when running `npm run dev` locally for convenience.
# When true, you must also fill in the VITE_ prefixed keys below.
VITE_USE_DIRECT_API=false

# Only needed if VITE_USE_DIRECT_API=true (local dev without `vercel dev`)
VITE_TMDB_API_KEY=
VITE_TRAKT_CLIENT_ID=
VITE_GEMINI_API_KEY=
